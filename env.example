# =============================================
# CONFIGURAÇÕES DO BANCO DE DADOS (MySQL)
# =============================================
DB_HOST=localhost
DB_USER=seu_usuario
DB_PASS=sua_senha
DB_NAME=nome_do_banco

# =============================================
# CONFIGURAÇÕES DO NETBOX
# =============================================
# URL base da instância NetBox (sem barra no final)
NB_URL=https://netbox.sua-empresa.com

# Token de API (gere em: Admin > API Tokens > Add Token)
NB_TOKEN=seu_token_de_api_aqui
